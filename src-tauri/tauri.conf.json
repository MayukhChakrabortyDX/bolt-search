{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bolt-search",
  "version": "0.1.0",
  "identifier": "com.mayukh.bolt-search",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "bolt-search",
        "width": 800,
        "height": 600,
        "minWidth": 1280,
        "minHeight": 720,
        "maximized": true,
        "visible": false,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/yt-dlp"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
