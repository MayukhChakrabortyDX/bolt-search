{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bolt Search",
  "version": "0.1.0",
  "identifier": "com.icecubeapps.bolt-search",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Bolt Search",
        "width": 800,
        "height": 600,
        "minWidth": 1280,
        "minHeight": 720,
        "maximized": true,
        "visible": false,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "windows": {
      "certificateThumbprint": "370BB885F538B0C872DBADD8EDEE6051B272F9F1",
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "publisher": "Ice Cube Apps",
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}